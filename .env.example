# Copy this file to .env and fill in your real values
# Windows:  copy .env.example .env
# Mac/Linux: cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
API_KEY=choose-any-secret-key-for-ui-login

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=pdf_rag
QDRANT_API_KEY=
USE_GRPC=true
QDRANT_GRPC_PORT=6334

# ── Models ────────────────────────────────────────────────────────────────────
OPENAI_EMBED_BATCH_SIZE=512
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072
LLM_MODEL=gpt-4o

# ── Retrieval ─────────────────────────────────────────────────────────────────
RERANKER_MODEL=BAAI/bge-reranker-large
MAX_RETRIEVAL_CHUNKS=40
TOP_K_FINAL=10
FAITHFULNESS_THRESHOLD=0.75
CONSISTENCY_SAMPLES=3

# ── Advanced retrieval (all on by default) ────────────────────────────────────
RAG_FUSION_ENABLED=true
RAG_FUSION_NUM_QUERIES=3
STEP_BACK_ENABLED=true
SENTENCE_WINDOW_ENABLED=true
SENTENCE_WINDOW_SIZE=2
CONTEXTUAL_COMPRESSION_ENABLED=true
CONTEXTUAL_COMPRESSION_MODEL=gpt-4o-mini
QUERY_ROUTING_ENABLED=true
HYDE_ENABLED=true
HYDE_MODEL=gpt-4o-mini
MMR_ENABLED=true
MMR_LAMBDA=0.5

# ── Ingestion ─────────────────────────────────────────────────────────────────
# Set FIGURE_DESCRIPTION_ENABLED=false for a faster first ingest,
# then re-enable and re-ingest any PDFs with important figures.
FIGURE_DESCRIPTION_ENABLED=true
FIGURE_DESCRIPTION_MODEL=gpt-4o
FIGURE_DESCRIPTION_MAX_PER_DOC=20
OCR_ENABLED=true
OCR_MIN_WORDS_THRESHOLD=50

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false
HOST=0.0.0.0
PORT=8000
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
